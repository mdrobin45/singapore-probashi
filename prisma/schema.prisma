generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  USER
}

enum OtpType {
  EMAIL_VERIFICATION
  FORGOT_PASSWORD
}

enum ShareStatus {
  AVAILABLE
  SOLD
  LISTED_FOR_SALE
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
  COMPLETED
}

enum PurchaseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentMethod {
  BANK_TRANSFER
  BKASH
  NAGAD
  ROCKET
  WALLET
}

enum WalletTxType {
  DEPOSIT
  WITHDRAWAL
  SHARE_PURCHASE
  SHARE_SALE
  REFUND
}

enum DepositStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaxiStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum TicketBookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LostFoundType {
  LOST
  FOUND
}

enum LostFoundStatus {
  OPEN
  RESOLVED
  REMOVED
}

enum NotificationType {
  SYSTEM
  PURCHASE
  WALLET
  TRADE
  OTP
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  fullName     String
  nidNumber    String?  @unique
  email        String   @unique
  phone        String?
  passwordHash String?
  googleId     String?  @unique
  profilePhoto String?
  role         Role     @default(USER)
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  otpTokens            OtpToken[]
  wallet               Wallet?
  sharePurchases       SharePurchaseRequest[]
  shareListings        ShareListing[]
  shareTrades          ShareTrade[]         @relation("BuyerTrades")
  ownedShares          ShareOwnership[]
  depositRequests      DepositRequest[]
  ticketBookings       TicketBookingRequest[]
  referrals            TicketReferral[]
  taxiRequests         TaxiRequest[]
  blogPosts            Blog[]
  islamicArticles      IslamicArticle[]
  pdfDocuments         PdfDocument[]
  lostFoundPosts       LostFoundPost[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  processedPurchases   SharePurchaseRequest[] @relation("PurchaseProcessor")
  processedListings    ShareTrade[]           @relation("TradeProcessor")
  processedDeposits    DepositRequest[]       @relation("DepositProcessor")
  createdProjects      Project[]

  @@index([email])
  @@index([nidNumber])
}

model OtpToken {
  id        String   @id @default(cuid())
  userId    String
  email     String
  token     String
  type      OtpType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, token])
}

model PendingRegistration {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  phone        String
  passwordHash String
  otp          String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([email])
}

// ─────────────────────────────────────────────
// SHARE INVESTMENT MARKETPLACE
// ─────────────────────────────────────────────

model Project {
  id               String        @id @default(cuid())
  name             String
  description      String
  totalShares      Int
  sharePrice       Decimal       @db.Decimal(12, 2)
  availableShares  Int
  status           ProjectStatus @default(ACTIVE)
  createdById      String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  createdBy        User              @relation(fields: [createdById], references: [id])
  shares           ShareOwnership[]
  purchaseRequests SharePurchaseRequest[]
  listings         ShareListing[]
  priceHistory     ProjectPriceHistory[]
}

model ProjectPriceHistory {
  id        String   @id @default(cuid())
  projectId String
  oldPrice  Decimal  @db.Decimal(12, 2)
  newPrice  Decimal  @db.Decimal(12, 2)
  changedAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ShareOwnership {
  id            String   @id @default(cuid())
  projectId     String
  ownerId       String
  quantity      Int
  purchasePrice Decimal  @db.Decimal(12, 2)
  acquiredAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
  owner   User    @relation(fields: [ownerId], references: [id])

  @@unique([projectId, ownerId])
}

model SharePurchaseRequest {
  id            String         @id @default(cuid())
  buyerId       String
  projectId     String
  quantity      Int
  totalAmount   Decimal        @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  txId          String?
  screenshotUrl String?
  status        PurchaseStatus @default(PENDING)
  adminNote     String?
  processedById String?
  processedAt   DateTime?
  createdAt     DateTime       @default(now())

  buyer       User     @relation(fields: [buyerId], references: [id])
  project     Project  @relation(fields: [projectId], references: [id])
  processedBy User?    @relation("PurchaseProcessor", fields: [processedById], references: [id])
}

model ShareListing {
  id           String         @id @default(cuid())
  sellerId     String
  projectId    String
  quantity     Int
  askingPrice  Decimal        @db.Decimal(12, 2)
  status       PurchaseStatus @default(PENDING)
  adminNote    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  seller User         @relation(fields: [sellerId], references: [id])
  project Project     @relation(fields: [projectId], references: [id])
  trades  ShareTrade[]
}

model ShareTrade {
  id            String         @id @default(cuid())
  listingId     String
  buyerId       String
  quantity      Int
  totalAmount   Decimal        @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  txId          String?
  screenshotUrl String?
  status        PurchaseStatus @default(PENDING)
  adminNote     String?
  processedById String?
  processedAt   DateTime?
  createdAt     DateTime       @default(now())

  listing     ShareListing @relation(fields: [listingId], references: [id])
  buyer       User         @relation("BuyerTrades", fields: [buyerId], references: [id])
  processedBy User?        @relation("TradeProcessor", fields: [processedById], references: [id])
}

// ─────────────────────────────────────────────
// WALLET
// ─────────────────────────────────────────────

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @db.Decimal(12, 2) @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String       @id @default(cuid())
  walletId    String
  type        WalletTxType
  amount      Decimal      @db.Decimal(12, 2)
  description String
  referenceId String?
  balanceBefore Decimal    @db.Decimal(12, 2)
  balanceAfter  Decimal    @db.Decimal(12, 2)
  createdAt   DateTime     @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
}

model DepositRequest {
  id            String        @id @default(cuid())
  userId        String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  txId          String
  screenshotUrl String?
  status        DepositStatus @default(PENDING)
  adminNote     String?
  processedById String?
  processedAt   DateTime?
  createdAt     DateTime      @default(now())

  user        User  @relation(fields: [userId], references: [id])
  processedBy User? @relation("DepositProcessor", fields: [processedById], references: [id])
}

// ─────────────────────────────────────────────
// AIR TICKET MODULE
// ─────────────────────────────────────────────

model AirTicketListing {
  id          String        @id @default(cuid())
  airline     String
  origin      String
  destination String
  departDate  DateTime
  returnDate  DateTime?
  price       Decimal       @db.Decimal(10, 2)
  seats       Int
  status      ContentStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now())

  bookings  TicketBookingRequest[]
  referrals TicketReferral[]
}

model TicketBookingRequest {
  id         String              @id @default(cuid())
  userId     String
  listingId  String
  passengers Int                 @default(1)
  totalPrice Decimal             @db.Decimal(10, 2)
  referralCode String?
  status     TicketBookingStatus @default(PENDING)
  notes      String?
  createdAt  DateTime            @default(now())

  user    User             @relation(fields: [userId], references: [id])
  listing AirTicketListing @relation(fields: [listingId], references: [id])
}

model TicketReferral {
  id           String   @id @default(cuid())
  referrerId   String
  listingId    String
  referralCode String   @unique
  bookingCount Int      @default(0)
  totalEarnings Decimal @db.Decimal(10, 2) @default(0)
  createdAt    DateTime @default(now())

  referrer User             @relation(fields: [referrerId], references: [id])
  listing  AirTicketListing @relation(fields: [listingId], references: [id])
}

// ─────────────────────────────────────────────
// TAXI RENT REQUEST
// ─────────────────────────────────────────────

model TaxiRequest {
  id             String     @id @default(cuid())
  userId         String
  pickupLocation String
  destination    String
  date           DateTime
  passengerCount Int        @default(1)
  vehicleType    String
  notes          String?
  status         TaxiStatus @default(PENDING)
  adminNote      String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ─────────────────────────────────────────────
// BLOG
// ─────────────────────────────────────────────

model BlogCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  blogs Blog[]
}

model BlogTag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  blogs BlogTagRelation[]
}

model Blog {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  content         String
  excerpt         String?
  featuredImage   String?
  authorId        String
  categoryId      String?
  status          ContentStatus @default(DRAFT)
  metaTitle       String?
  metaDescription String?
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  author   User          @relation(fields: [authorId], references: [id])
  category BlogCategory? @relation(fields: [categoryId], references: [id])
  tags     BlogTagRelation[]

  @@index([slug])
  @@index([status])
}

model BlogTagRelation {
  blogId String
  tagId  String

  blog Blog    @relation(fields: [blogId], references: [id], onDelete: Cascade)
  tag  BlogTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogId, tagId])
}

// ─────────────────────────────────────────────
// ISLAMIC KNOWLEDGE CENTER
// ─────────────────────────────────────────────

model Surah {
  id           String @id @default(cuid())
  number       Int    @unique
  arabicName   String
  englishName  String
  meaningName  String
  totalVerses  Int
  revelationType String
}

model Dua {
  id             String @id @default(cuid())
  title          String
  arabic         String
  transliteration String?
  translation    String
  category       String
  source         String?
  createdAt      DateTime @default(now())
}

model IslamicArticle {
  id        String        @id @default(cuid())
  title     String
  content   String
  excerpt   String?
  authorId  String
  status    ContentStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  author User @relation(fields: [authorId], references: [id])
}

model PdfDocument {
  id          String        @id @default(cuid())
  title       String
  description String?
  fileUrl     String
  category    String
  authorId    String
  status      ContentStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now())

  author User @relation(fields: [authorId], references: [id])
}

// ─────────────────────────────────────────────
// LOST & FOUND
// ─────────────────────────────────────────────

model LostFoundPost {
  id          String          @id @default(cuid())
  userId      String
  type        LostFoundType
  title       String
  description String
  location    String?
  images      String[]
  status      LostFoundStatus @default(OPEN)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([type, status])
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entity     String
  entityId   String?
  data       Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
}

// ─────────────────────────────────────────────
// SITE SETTINGS
// ─────────────────────────────────────────────

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// BANK RATES
// ─────────────────────────────────────────────

model BankRate {
  id        String   @id @default(cuid())
  bankName  String
  rate      Decimal  @db.Decimal(10, 4)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
