generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  USER
}

enum OtpType {
  EMAIL_VERIFICATION
  FORGOT_PASSWORD
}

enum ShareStatus {
  AVAILABLE
  SOLD
  LISTED_FOR_SALE
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
  COMPLETED
}

enum PurchaseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentMethod {
  BANK_TRANSFER
  BKASH
  NAGAD
  ROCKET
  WALLET
}

enum WalletTxType {
  DEPOSIT
  WITHDRAWAL
  SHARE_PURCHASE
  SHARE_SALE
  REFUND
  COMMISSION
}

enum DepositStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  ASSIGNED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum CheckoutStatus {
  DRAFT
  AWAITING_PAYMENT
  PROOF_SUBMITTED
  PAID
  REJECTED
  CANCELLED
}

enum CheckoutItemType {
  TAXI
  AIR_TICKET
  SERVICE
  CUSTOM
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LostFoundType {
  LOST
  FOUND
}

enum LostFoundStatus {
  OPEN
  RESOLVED
  REMOVED
}

enum NotificationType {
  SYSTEM
  PURCHASE
  WALLET
  TRADE
  OTP
}

enum ApplyStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  fullName     String
  nidNumber    String?  @unique
  email        String   @unique
  phone        String?
  passwordHash String?
  googleId     String?  @unique
  profilePhoto String?
  role         Role     @default(USER)
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  isAgent      Boolean  @default(false)
  referralCode String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  otpTokens            OtpToken[]
  wallet               Wallet?
  sharePurchases       SharePurchaseRequest[]
  referredSharePurchases SharePurchaseRequest[] @relation("SharePurchaseReferrer")
  referredTaxiRequests   TaxiRequest[]          @relation("TaxiReferrer")
  referredAirTicketRequests AirTicketRequest[]  @relation("AirTicketReferrer")
  referredServiceRequests   ServiceRequest[]    @relation("ServiceReferrer")
  shareListings        ShareListing[]
  shareTrades          ShareTrade[]         @relation("BuyerTrades")
  ownedShares          ShareOwnership[]
  depositRequests      DepositRequest[]
  withdrawalRequests   WithdrawalRequest[]
  taxiRequests         TaxiRequest[]
  managedTaxiRequests  TaxiRequest[]          @relation("TaxiManagerAssignment")
  processedTaxiRequests TaxiRequest[]         @relation("TaxiProcessedBy")
  airTicketRequests        AirTicketRequest[]
  managedAirTicketRequests AirTicketRequest[] @relation("AirTicketManagerAssignment")
  processedAirTicketRequests AirTicketRequest[] @relation("AirTicketProcessedBy")
  checkouts            Checkout[]
  createdCheckouts     Checkout[]             @relation("CheckoutCreatedBy")
  processedCheckouts   Checkout[]             @relation("CheckoutProcessedBy")
  serviceRequests      ServiceRequest[]
  blogPosts            Blog[]
  islamicArticles      IslamicArticle[]
  pdfDocuments         PdfDocument[]
  lostFoundPosts       LostFoundPost[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  applyApplications    ApplyApplication[]
  shareCertificates    ShareCertificate[]
  processedPurchases   SharePurchaseRequest[] @relation("PurchaseProcessor")
  processedListings    ShareTrade[]           @relation("TradeProcessor")
  processedDeposits    DepositRequest[]       @relation("DepositProcessor")
  processedWithdrawals WithdrawalRequest[]    @relation("WithdrawalProcessor")
  createdProjects      Project[]
  buyRequests          ShareBuyRequest[]      @relation("BuyRequestBuyer")
  processedBuyRequests ShareBuyRequest[]      @relation("BuyRequestProcessor")

  @@index([email])
  @@index([nidNumber])
}

model OtpToken {
  id        String   @id @default(cuid())
  userId    String
  email     String
  token     String
  type      OtpType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, token])
}

model PendingRegistration {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  phone        String
  passwordHash String
  otp          String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([email])
}

// ─────────────────────────────────────────────
// SHARE INVESTMENT MARKETPLACE
// ─────────────────────────────────────────────

model Project {
  id               String        @id @default(cuid())
  name             String
  description      String
  imageUrl         String?
  totalShares      Int
  sharePriceSgd    Decimal       @db.Decimal(12, 2) // per-share list price in SGD — actual payment is converted to BDT at purchase time, see lib/share-pricing.ts
  availableShares  Int
  status           ProjectStatus @default(ACTIVE)
  createdById      String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  createdBy        User              @relation(fields: [createdById], references: [id])
  shares           ShareOwnership[]
  purchaseRequests SharePurchaseRequest[]
  listings         ShareListing[]
  priceHistory     ProjectPriceHistory[]
  certificates     ShareCertificate[]
}

model ShareCertificate {
  id          String    @id @default(cuid())
  projectId   String
  shareNumber Int
  ownerId     String?   // null = available (not yet assigned)
  issuedAt    DateTime? // set when assigned to an owner

  project Project @relation(fields: [projectId], references: [id])
  owner   User?   @relation(fields: [ownerId], references: [id])

  @@unique([projectId, shareNumber])
  @@index([projectId, ownerId])
}

model ProjectPriceHistory {
  id        String   @id @default(cuid())
  projectId String
  oldPrice  Decimal  @db.Decimal(12, 2)
  newPrice  Decimal  @db.Decimal(12, 2)
  changedAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ShareOwnership {
  id            String   @id @default(cuid())
  projectId     String
  ownerId       String
  quantity      Int
  purchasePrice Decimal  @db.Decimal(12, 2)
  acquiredAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
  owner   User    @relation(fields: [ownerId], references: [id])

  @@unique([projectId, ownerId])
}

model SharePurchaseRequest {
  id            String         @id @default(cuid())
  buyerId       String
  projectId     String
  quantity      Int
  totalAmount   Decimal        @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  txId          String?
  screenshotUrl String?
  status        PurchaseStatus @default(PENDING)
  adminNote     String?
  referredById  String?
  processedById String?
  processedAt   DateTime?
  createdAt     DateTime       @default(now())

  buyer       User     @relation(fields: [buyerId], references: [id])
  project     Project  @relation(fields: [projectId], references: [id])
  referredBy  User?    @relation("SharePurchaseReferrer", fields: [referredById], references: [id])
  processedBy User?    @relation("PurchaseProcessor", fields: [processedById], references: [id])
}

model ShareListing {
  id           String         @id @default(cuid())
  sellerId     String
  projectId    String
  quantity     Int
  askingPrice  Decimal        @db.Decimal(12, 2)
  status       PurchaseStatus @default(PENDING)
  adminNote    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  seller User         @relation(fields: [sellerId], references: [id])
  project Project     @relation(fields: [projectId], references: [id])
  trades  ShareTrade[]
}

model ShareTrade {
  id            String         @id @default(cuid())
  listingId     String
  buyerId       String
  quantity      Int
  totalAmount   Decimal        @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  txId          String?
  screenshotUrl String?
  status        PurchaseStatus @default(PENDING)
  adminNote     String?
  processedById String?
  processedAt   DateTime?
  createdAt     DateTime       @default(now())

  listing     ShareListing @relation(fields: [listingId], references: [id])
  buyer       User         @relation("BuyerTrades", fields: [buyerId], references: [id])
  processedBy User?        @relation("TradeProcessor", fields: [processedById], references: [id])
}

enum ShareSize {
  SMALL
  BIG
}

model ShareBuyRequest {
  id            String         @id @default(cuid())
  buyerId       String
  name          String
  shareNumber   String
  size          ShareSize
  price         Decimal        @db.Decimal(12, 2)
  preferredDate DateTime
  status        PurchaseStatus @default(PENDING)
  adminNote     String?
  processedById String?
  processedAt   DateTime?
  createdAt     DateTime       @default(now())

  buyer       User  @relation("BuyRequestBuyer", fields: [buyerId], references: [id])
  processedBy User? @relation("BuyRequestProcessor", fields: [processedById], references: [id])
}

// ─────────────────────────────────────────────
// WALLET
// ─────────────────────────────────────────────

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @db.Decimal(12, 2) @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String       @id @default(cuid())
  walletId    String
  type        WalletTxType
  amount      Decimal      @db.Decimal(12, 2)
  description String
  referenceId String?
  balanceBefore Decimal    @db.Decimal(12, 2)
  balanceAfter  Decimal    @db.Decimal(12, 2)
  createdAt   DateTime     @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
}

model DepositRequest {
  id            String        @id @default(cuid())
  userId        String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  txId          String
  screenshotUrl String?
  status        DepositStatus @default(PENDING)
  adminNote     String?
  processedById String?
  processedAt   DateTime?
  createdAt     DateTime      @default(now())

  user        User  @relation(fields: [userId], references: [id])
  processedBy User? @relation("DepositProcessor", fields: [processedById], references: [id])
}

model WithdrawalRequest {
  id            String        @id @default(cuid())
  userId        String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  accountNumber String
  accountName   String
  status        DepositStatus @default(PENDING)
  adminNote     String?
  processedById String?
  processedAt   DateTime?
  createdAt     DateTime      @default(now())

  user        User  @relation(fields: [userId], references: [id])
  processedBy User? @relation("WithdrawalProcessor", fields: [processedById], references: [id])
}

// ─────────────────────────────────────────────
// AIR TICKET MODULE
// ─────────────────────────────────────────────

model AirTicketRequest {
  id                String        @id @default(cuid())
  userId            String
  origin            String
  destination       String
  departDate        DateTime
  returnDate        DateTime?
  passengers        Int           @default(1)
  notes             String?
  status            BookingStatus @default(PENDING)
  adminNote         String?
  price             Decimal?      @db.Decimal(10, 2)
  assignedManagerId String?
  referredById      String?
  processedById     String?
  processedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  assignedManager User?         @relation("AirTicketManagerAssignment", fields: [assignedManagerId], references: [id])
  referredBy      User?         @relation("AirTicketReferrer", fields: [referredById], references: [id])
  processedBy     User?         @relation("AirTicketProcessedBy", fields: [processedById], references: [id])
  checkoutItem    CheckoutItem?
}

// ─────────────────────────────────────────────
// TAXI RENT REQUEST
// ─────────────────────────────────────────────

model TaxiRequest {
  id                String        @id @default(cuid())
  userId            String
  pickupLocation    String
  destination       String
  date              DateTime
  passengerCount    Int           @default(1)
  notes             String?
  status            BookingStatus @default(PENDING)
  adminNote         String?
  price             Decimal?      @db.Decimal(10, 2)
  assignedVendorId  String?
  assignedManagerId String?
  referredById      String?
  processedById     String?
  processedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  assignedVendor  TaxiVendor?   @relation(fields: [assignedVendorId], references: [id])
  assignedManager User?         @relation("TaxiManagerAssignment", fields: [assignedManagerId], references: [id])
  referredBy      User?         @relation("TaxiReferrer", fields: [referredById], references: [id])
  processedBy     User?         @relation("TaxiProcessedBy", fields: [processedById], references: [id])
  checkoutItem    CheckoutItem?
}

model TaxiVendor {
  id          String   @id @default(cuid())
  name        String
  phone       String
  vehicleType String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  taxiRequests TaxiRequest[]
}

// ─────────────────────────────────────────────
// CHECKOUT (multi-item WhatsApp-negotiated payment)
// ─────────────────────────────────────────────

model Checkout {
  id             String         @id @default(cuid())
  token          String         @unique
  userId         String
  subtotal       Decimal        @db.Decimal(12, 2)
  discountAmount Decimal        @db.Decimal(12, 2) @default(0)
  totalAmount    Decimal        @db.Decimal(12, 2)
  status         CheckoutStatus @default(DRAFT)
  paymentMethod  PaymentMethod?
  txId           String?
  screenshotUrl  String?
  adminNote      String?
  createdById    String
  processedById  String?
  processedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user        User           @relation(fields: [userId], references: [id])
  createdBy   User           @relation("CheckoutCreatedBy", fields: [createdById], references: [id])
  processedBy User?          @relation("CheckoutProcessedBy", fields: [processedById], references: [id])
  items       CheckoutItem[]
}

model CheckoutItem {
  id                 String           @id @default(cuid())
  checkoutId         String
  itemType           CheckoutItemType
  taxiRequestId      String?          @unique
  airTicketRequestId String?          @unique
  serviceRequestId   String?          @unique
  description        String
  quantity            Int             @default(1)
  unitPrice           Decimal         @db.Decimal(12, 2)
  lineTotal           Decimal         @db.Decimal(12, 2)
  createdAt           DateTime        @default(now())

  checkout         Checkout          @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  taxiRequest      TaxiRequest?      @relation(fields: [taxiRequestId], references: [id])
  airTicketRequest AirTicketRequest? @relation(fields: [airTicketRequestId], references: [id])
  serviceRequest   ServiceRequest?   @relation(fields: [serviceRequestId], references: [id])
}

// ─────────────────────────────────────────────
// BLOG
// ─────────────────────────────────────────────

model BlogCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  blogs Blog[]
}

model BlogTag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  blogs BlogTagRelation[]
}

model Blog {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  content         String
  excerpt         String?
  featuredImage   String?
  authorId        String
  categoryId      String?
  status          ContentStatus @default(DRAFT)
  metaTitle       String?
  metaDescription String?
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  author   User          @relation(fields: [authorId], references: [id])
  category BlogCategory? @relation(fields: [categoryId], references: [id])
  tags     BlogTagRelation[]

  @@index([slug])
  @@index([status])
}

model BlogTagRelation {
  blogId String
  tagId  String

  blog Blog    @relation(fields: [blogId], references: [id], onDelete: Cascade)
  tag  BlogTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogId, tagId])
}

// ─────────────────────────────────────────────
// ISLAMIC KNOWLEDGE CENTER
// ─────────────────────────────────────────────

model Surah {
  id           String @id @default(cuid())
  number       Int    @unique
  arabicName   String
  englishName  String
  meaningName  String
  totalVerses  Int
  revelationType String
}

model Dua {
  id             String @id @default(cuid())
  title          String
  arabic         String
  transliteration String?
  translation    String
  category       String
  source         String?
  createdAt      DateTime @default(now())
}

model IslamicArticle {
  id        String        @id @default(cuid())
  title     String
  content   String
  excerpt   String?
  authorId  String
  status    ContentStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  author User @relation(fields: [authorId], references: [id])
}

model PdfDocument {
  id          String        @id @default(cuid())
  title       String
  description String?
  fileUrl     String
  category    String
  authorId    String
  status      ContentStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now())

  author User @relation(fields: [authorId], references: [id])
}

// ─────────────────────────────────────────────
// LOST & FOUND
// ─────────────────────────────────────────────

model LostFoundPost {
  id          String          @id @default(cuid())
  userId      String
  type        LostFoundType
  title       String
  description String
  location    String?
  images      String[]
  status      LostFoundStatus @default(OPEN)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([type, status])
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entity     String
  entityId   String?
  data       Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
}

// ─────────────────────────────────────────────
// SITE SETTINGS
// ─────────────────────────────────────────────

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// BANK RATES
// ─────────────────────────────────────────────

model BankRate {
  id        String   @id @default(cuid())
  bankName  String
  rate      Decimal  @db.Decimal(10, 4)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// APPLY / SERVICE APPLICATIONS
// ─────────────────────────────────────────────

model ApplyService {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications     ApplyApplication[]
  serviceRequests  ServiceRequest[]
}

model ServiceRequest {
  id            String      @id @default(cuid())
  serviceId     String
  userId        String?     // nullable — submission doesn't require login; admin can link to a customer account for checkout bundling

  fullName      String
  phone         String
  email         String

  passportUrl   String?
  nidUrl        String?
  photoUrl      String?
  workPermitUrl String?
  otherUrl      String?

  status        ApplyStatus @default(PENDING)
  adminNote     String?
  referredById  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  service      ApplyService  @relation(fields: [serviceId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])
  referredBy   User?         @relation("ServiceReferrer", fields: [referredById], references: [id])
  checkoutItem CheckoutItem?

  @@index([serviceId])
  @@index([email])
}

model ApplyApplication {
  id             String      @id @default(cuid())
  userId         String
  serviceId      String
  resumeUrl      String?
  ePassportUrl   String?
  permitUrl      String?
  oldPassportUrl String?
  otherFileUrl   String?
  status         ApplyStatus @default(PENDING)
  adminNote      String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user    User         @relation(fields: [userId], references: [id])
  service ApplyService @relation(fields: [serviceId], references: [id])

  @@index([userId])
  @@index([serviceId])
}
